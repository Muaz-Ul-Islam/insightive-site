---
import Base from '../layouts/Base.astro';
import { partners } from '../data/partners.js';
import { fetchPage, fetchPartners, lexicalNodeToHtml } from '../lib/payload';

const PAYLOAD_CMS_URL = import.meta.env.PAYLOAD_CMS_URL || 'http://127.0.0.1:3000';

let pageData: any = null;
let cmsPartners: any[] = [];
try {
  pageData = await fetchPage('partners');
  cmsPartners = await fetchPartners();
} catch (e) {
  console.warn('[Partners Page] Failed to fetch data from Payload CMS, using static fallback.', e);
}

const metaTitle = pageData?.meta?.title || pageData?.title || "Partners — Our Delivery Network | Insightive";
const metaDescription = pageData?.meta?.description || "Trusted delivery partners for work Insightive doesn't run in-house. An Advisory recommendation can point to Devsinc for Shopify, ThisWayUP for Amazon, Unity Retail for logistics or Synarc for marketing. The advice stays independent and carries no margin.";

const layout = pageData?.layout || [];
const hasDynamicLayout = layout.length > 0;

// Normalize CMS partners to match the local data shape
const partnerList = cmsPartners.length > 0
  ? cmsPartners.map((p: any) => ({
      id: p.slug || p.id,
      name: p.name,
      capability: p.capability,
      blurb: p.blurb,
      url: p.url,
      logo: p.logo?.url ? (p.logo.url.startsWith('/') ? `${PAYLOAD_CMS_URL}${p.logo.url}` : p.logo.url) : null,
      mark: p.mark?.url ? (p.mark.url.startsWith('/') ? `${PAYLOAD_CMS_URL}${p.mark.url}` : p.mark.url) : null,
      logoReady: p.logoReady ?? false,
    }))
  : partners;
---

<Base
  title={metaTitle}
  description={metaDescription}
>
  {hasDynamicLayout ? (
    layout.map((block: any) => {
      const { blockType } = block;

      if (blockType === 'sectionProse') {
        const titleNode = block.title?.root;
        let titleHtml = '';
        if (titleNode) {
          const parsed = lexicalNodeToHtml(titleNode, { italicClass: 'serif-em tick' });
          titleHtml = parsed.replace(/^<[a-zA-Z0-9]+>/, '').replace(/<\/[a-zA-Z0-9]+>$/, '');
        }
        const contentHtml = block.content?.root ? lexicalNodeToHtml(block.content.root) : '';
        const isHero = block.eyebrow?.toLowerCase() === 'partners';

        return (
          <section class:list={['section', { tinted: block.tinted, band: !isHero }]}>
            <div class="container">
              {block.eyebrow && <p class="eyebrow">{block.eyebrow}</p>}
              {isHero ? (
                titleHtml ? <h1 set:html={titleHtml} /> : <h1>{block.title || ''}</h1>
              ) : (
                titleHtml ? <h2 set:html={titleHtml} /> : <h2>{block.title || ''}</h2>
              )}
              {contentHtml && (
                <div class={isHero ? 'sub' : 'band-lead'} set:html={contentHtml} />
              )}
            </div>
          </section>
        );
      }

      if (blockType === 'editorialSplit') {
        const titleNode = block.title?.root;
        let titleHtml = '';
        if (titleNode) {
          const parsed = lexicalNodeToHtml(titleNode, { italicClass: 'serif-em' });
          titleHtml = parsed.replace(/^<[a-zA-Z0-9]+>/, '').replace(/<\/[a-zA-Z0-9]+>$/, '');
        }
        const contentHtml = block.content?.root ? lexicalNodeToHtml(block.content.root) : '';

        return (
          <section class={`section ${block.tinted ? 'tinted' : ''} band`}>
            <div class="container">
              {block.eyebrow && <p class="eyebrow">{block.eyebrow}</p>}
              {titleHtml && <h2 set:html={titleHtml} />}
              {contentHtml && <div class="band-lead" set:html={contentHtml} />}
            </div>
          </section>
        );
      }

      if (blockType === 'partnersList') {
        return (
          <>
            {partnerList.map((p: any, i: number) => (
              <section class:list={['section', 'partner', { tinted: i % 2 === 1 }]} id={p.id}>
                <div class="container partner-row">
                  <div class="pmark">
                    {p.logoReady ? <img src={p.mark || p.logo} alt={`${p.name} logo`} loading="lazy" decoding="async" /> : <span>{p.name}</span>}
                  </div>
                  <div class="pinfo">
                    <p class="eyebrow">{p.capability}</p>
                    <h2>{p.name}</h2>
                    <p>{p.blurb}</p>
                    {p.url
                      ? <a class="plink" href={p.url} target="_blank" rel="noopener">Visit {p.name} →</a>
                      : <span class="plink-muted">Website link coming soon</span>}
                  </div>
                </div>
              </section>
            ))}
          </>
        );
      }

      if (blockType === 'sectionCta') {
        return (
          <section class="section on-dark">
            <div class="container">
              {block.eyebrow && <p class="eyebrow">{block.eyebrow}</p>}
              <h2 set:html={block.title} />
              <p class="cta-sub">{block.body}</p>
              <a href={block.ctaLink} class="btn btn-primary">{block.ctaLabel}</a>
            </div>
          </section>
        );
      }

      return null;
    })
  ) : (
    <>
      <section class="section">
        <div class="container">
          <p class="eyebrow">Partners</p>
          <h1>Trusted partners for the work we <span class="serif-em tick">don't run in-house</span>.</h1>
          <p class="sub">
            Insightive advises and builds. When a recommendation points to execution we don't do
            in-house, like commerce channels, marketplaces, logistics or marketing, we name a
            delivery partner we trust. The advice that led there stays independent and carries no
            margin. Building software stays ours.
          </p>
        </div>
      </section>

      <section class="section tinted band">
        <div class="container">
          <p class="eyebrow">Delivery partners</p>
          <h2>We route the execution, never the advice.</h2>
          <p class="band-lead">
            These are the partners we bring in for capabilities we deliberately do not keep
            in-house. Each is named against the Advisory domain it serves. We take no referral
            margin, so the recommendation always stands on its own.
          </p>
        </div>
      </section>

      {partners.map((p, i) => (
        <section class:list={['section', 'partner', { tinted: i % 2 === 1 }]} id={p.id}>
          <div class="container partner-row">
            <div class="pmark">
              {p.logoReady ? <img src={p.mark || p.logo} alt={`${p.name} logo`} loading="lazy" decoding="async" /> : <span>{p.name}</span>}
            </div>
            <div class="pinfo">
              <p class="eyebrow">{p.capability}</p>
              <h2>{p.name}</h2>
              <p>{p.blurb}</p>
              {p.url
                ? <a class="plink" href={p.url} target="_blank" rel="noopener">Visit {p.name} →</a>
                : <span class="plink-muted">Website link coming soon</span>}
            </div>
          </div>
        </section>
      ))}

      <section class="section band">
        <div class="container">
          <p class="eyebrow">A note on partnership</p>
          <h2>Two kinds of partner, kept <span class="serif-em">distinct</span>.</h2>
          <p class="band-lead">
            <strong>Delivery partners</strong>, above, execute work we don't run in-house. They
            come out of an Advisory recommendation and we name them, with no margin to us.
          </p>
          <p class="band-lead">
            <strong>Technology partnerships</strong> are a different thing: the platforms we build
            our own solutions on, the cloud and infrastructure providers behind what we deliver.
            As we formalise those, they will sit here as exactly that, the foundation we build on
            rather than a service we hand off. We keep the line clear so you always know what
            Insightive does itself and what it delivers through others.
          </p>
        </div>
      </section>

      <section class="section on-dark">
        <div class="container">
          <p class="eyebrow">How it works</p>
          <h2>Need execution as well as a <span class="serif-em">decision</span>?</h2>
          <p class="cta-sub">
            Start with Advisory. We map the work, return the call and bring in the right partner
            where it is needed: named, labeled and independent of the recommendation.
          </p>
          <a href="/services/advisory" class="btn btn-primary">See Advisory</a>
        </div>
      </section>
    </>
  )}
</Base>

<style>
  section h1 { font-size: var(--text-2xl); font-weight: var(--w-light); margin: var(--s-4) 0; }
  .sub { max-width: 60ch; font-size: var(--text-md); color: var(--ink-soft); }
  .tinted { background: var(--paper-tint); }
  .band h2 { font-size: var(--text-xl); margin: var(--s-3) 0 var(--s-4); max-width: 26ch; }
  .band-lead { max-width: 64ch; color: var(--ink-soft); font-size: var(--text-md); margin-bottom: var(--s-3); }

  .partner { scroll-margin-top: 100px; border-top: 1px solid var(--hairline); }
  .partner-row {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: var(--s-6);
    align-items: center;
  }
  .pmark {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 120px;
    border: 1px solid var(--hairline);
    background: var(--paper);
  }
  .pmark span {
    font-family: var(--mono);
    font-weight: 500;
    font-size: var(--text-lg);
    letter-spacing: -0.02em;
    color: var(--navy);
  }
  .partner.tinted .pmark { background: var(--paper); }
  .pmark img { max-height: 72px; max-width: 160px; width: auto; height: auto; }
  .pinfo .eyebrow { margin-bottom: var(--s-2); }
  .pinfo h2 { font-size: var(--text-xl); margin-bottom: var(--s-3); }
  .pinfo p { color: var(--ink-soft); max-width: 60ch; margin-bottom: var(--s-4); }
  .plink { font-weight: var(--w-medium); font-size: var(--text-sm); color: var(--royal); text-decoration: none; }
  .plink:hover { text-decoration: underline; }
  .plink-muted { font-size: var(--text-sm); color: var(--ink-mute); }

  .on-dark h2 { font-size: var(--text-xl); margin-top: var(--s-3); }
  .cta-sub { max-width: 56ch; color: var(--soft-on-navy); margin: var(--s-3) 0 var(--s-5); font-size: var(--text-md); }

  @media (max-width: 760px) {
    .partner-row { grid-template-columns: 1fr; gap: var(--s-4); }
    .pmark { height: 96px; }
  }
</style>
