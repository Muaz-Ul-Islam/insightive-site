---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { fetchIndustries, fetchIndustryBySlug, fetchPage, lexicalNodeToHtml } from '../../lib/payload';

// ── Static paths ─────────────────────────────────────────────────────────────
export async function getStaticPaths() {
  // 1. Try Payload CMS first
  let cmsIndustries: any[] = [];
  try {
    cmsIndustries = await fetchIndustries();
  } catch (e) {
    console.warn('[Industries/[slug]] Failed to fetch Payload industries for paths.', e);
  }

  if (cmsIndustries.length > 0) {
    return cmsIndustries.map((ind: any) => ({
      params: { slug: ind.slug },
      props: { cmsInd: ind, localInd: null },
    }));
  }

  // 2. Fallback: local Markdown collection
  const localIndustries = await getCollection('industries');
  return localIndustries.map((ind) => ({
    params: { slug: ind.id.replace(/\.md$/, '') },
    props: { cmsInd: null, localInd: ind },
  }));
}

// ── Props & Re-fetching ──────────────────────────────────────────────────────
const { slug } = Astro.params;
let { cmsInd, localInd } = Astro.props;

// Re-fetch detailed doc to populate relationship fields (like relatedIndustries)
if (cmsInd) {
  try {
    const fresh = await fetchIndustryBySlug(slug);
    if (fresh) cmsInd = fresh;
  } catch {
    // keep static paths prop
  }
}

// Render local Markdown body if needed
let LocalContent: any = null;
if (localInd) {
  const { Content } = await render(localInd);
  LocalContent = Content;
}

// ── Data normalisation (Payload vs. local MD) ─────────────────────────────────
const name = cmsInd?.name ?? localInd?.data?.name ?? '';
const dek  = cmsInd?.dek  ?? localInd?.data?.dek  ?? '';

const rawMisfits: any[] = cmsInd?.misfits ?? localInd?.data?.misfits ?? [];
const rawBuilds: any[]  = cmsInd?.builds  ?? localInd?.data?.builds  ?? [];

const misfits: string[] = rawMisfits.map((m) =>
  typeof m === 'string' ? m : (m.misfit ?? m.value ?? String(m))
);
const builds: string[] = rawBuilds.map((b) =>
  typeof b === 'string' ? b : (b.build ?? b.value ?? String(b))
);

const rawFaq: any[] = cmsInd?.faq ?? localInd?.data?.faq ?? [];
const faq = rawFaq.map((f) => ({
  q: f.question ?? f.q ?? '',
  a: f.answer   ?? f.a ?? '',
}));

let proseHtml = '';
if (cmsInd?.content?.root) {
  proseHtml = lexicalNodeToHtml(cmsInd.content.root);
}

// ── Others / Related Industries ──────────────────────────────────────────────
let rawOthers: any[] = [];
if (cmsInd) {
  const related = cmsInd.relatedIndustries || [];
  rawOthers = related.filter((r: any) => r && typeof r === 'object');
  
  if (rawOthers.length === 0) {
    try {
      const allCms = await fetchIndustries();
      rawOthers = allCms.filter((i: any) => i.slug !== slug).slice(0, 3);
    } catch (e) {
      console.warn('Failed to fetch fallback related industries from CMS', e);
    }
  }
} else {
  try {
    const allLocal = await getCollection('industries');
    rawOthers = allLocal
      .filter((i) => i.id.replace(/\.md$/, '') !== slug)
      .sort((a, b) => a.data.order - b.data.order)
      .slice(0, 3);
  } catch (e) {
    console.warn('Failed to get local related industries', e);
  }
}

// Normalize others so that o.data.name and o.data.dek work for both CMS and markdown
const others = rawOthers.map((o: any) => {
  if (o.data) return o;
  return {
    ...o,
    data: {
      name: o.name || '',
      dek: o.dek || '',
    }
  };
});

function indSlug(o: any): string {
  return o.slug ?? o.id?.replace(/\.md$/, '') ?? '';
}

// ── Meta & Schema ────────────────────────────────────────────────────────────
const metaTitle       = `${name} — Fit-Built Software | Insightive`;
const metaDescription = dek;

const schema = faq.length
  ? [
      {
        '@type': 'FAQPage',
        mainEntity: faq.map((f) => ({
          '@type': 'Question',
          name: f.q,
          acceptedAnswer: { '@type': 'Answer', text: f.a },
        })),
      },
    ]
  : [];
  console.log('Industries DYNAMIC PAGE LOADED !')
---

<Base title={metaTitle} description={metaDescription} schema={schema}>

  {/* ── Hero ─────────────────────────────────────────────────────────── */}
  <section class="section">
    <div class="container">
      <p class="eyebrow">Industries · {name}</p>
      <h1>{name}</h1>
      <p class="sub">{dek}</p>
    </div>
  </section>

  {/* ── Misfit pattern / What we build grid ──────────────────────────── */}
  {(misfits.length > 0 || builds.length > 0) && (
    <section class="container ind-grid fade-up">
      <div>
        <h2 class="col-head">The misfit pattern</h2>
        <ul class="misfits">
          {misfits.map((m) => <li>{m}</li>)}
        </ul>
      </div>
      <div>
        <h2 class="col-head">What we build here</h2>
        <ul class="builds">
          {builds.map((b) => <li>{b}</li>)}
        </ul>
      </div>
    </section>
  )}

  {/* ── Prose body ───────────────────────────────────────────────────── */}
  <section class="section">
    <div class="container">
      <div class="prose ind-prose">
        {proseHtml ? (
          <div set:html={proseHtml} />
        ) : LocalContent ? (
          <LocalContent />
        ) : null}
      </div>
    </div>
  </section>

  {/* ── FAQ ──────────────────────────────────────────────────────────── */}
  {faq.length > 0 && (
    <section class="section faq-section">
      <div class="container">
        <p class="eyebrow">Common questions</p>
        <div class="faq-list fade-up">
          {faq.map((f) => (
            <div class="faq-item">
              <h2 class="faq-q">{f.q}</h2>
              <p class="faq-a">{f.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* ── Related Industries Section ── */}
  {others.length > 0 && (
    <section class="section related">
      <div class="container">
        <p class="eyebrow">Other industries we build for</p>
        <ul class="related-list">
          {others.map((o) => (
            <li>
              <a href={`/industries/${indSlug(o)}`}>
                <span class="rl-title">{o.data.name}</span>
                <span class="rl-dek">{o.data.dek}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  {/* ── CTA Section ── */}
  <section class="section on-dark">
    <div class="container">
      <h2>Recognize the pattern?</h2>
      <p class="cta-sub">
        A two-week Fit Assessment maps your specific misfit, prices it and returns the
        call: stay, extend or build.
      </p>
      <a href="/contact?service=build" class="btn btn-primary">Book a Fit Assessment</a>
    </div>
  </section>

</Base>

<style>
  section h1 { font-size: var(--text-2xl); font-weight: var(--w-light); margin: var(--s-4) 0; }
  .sub { max-width: 56ch; font-size: var(--text-md); color: var(--ink-soft); }
  .ind-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-6);
  }
  .col-head {
    font-family: var(--mono);
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--royal);
    margin-bottom: var(--s-4);
    font-weight: 500;
  }
  .misfits, .builds { list-style: none; padding: 0; }
  .misfits li, .builds li {
    padding: var(--s-3) 0;
    border-bottom: 1px solid var(--hairline);
    color: var(--ink-soft);
  }
  /* The "build" column is the answer — render it with more presence than the misfit list. */
  .builds li {
    color: var(--ink);
    padding-left: var(--s-4);
    position: relative;
  }
  .builds li::before {
    content: '';
    position: absolute;
    left: 0;
    top: calc(var(--s-3) + 0.6em);
    width: 10px;
    height: 1px;
    background: var(--royal);
  }
  .ind-prose { font-size: var(--text-md); color: var(--ink-soft); }

  /* ---- FAQ (was schema-only; now on-page) ----
     Questions sit on one line where the viewport allows: smaller, bolder and
     released from the heading's balanced two-line wrap. Answers stay short. */
  .faq-section { background: var(--paper-tint); }
  .faq-list { margin-top: var(--s-5); max-width: 860px; }
  .faq-item {
    padding: var(--s-4) 0;
    border-top: 1px solid var(--hairline);
  }
  .faq-item:first-child { border-top: 0; padding-top: 0; }
  .faq-q {
    font-size: var(--text-base);
    font-weight: var(--w-bold);
    line-height: 1.35;
    letter-spacing: -0.005em;
    text-wrap: normal;
    margin-bottom: var(--s-2);
  }
  .faq-a { color: var(--ink-soft); font-size: var(--text-base); line-height: 1.6; max-width: 70ch; }

  .on-dark h2 { font-size: var(--text-xl); }
  .cta-sub { color: var(--soft-on-navy); max-width: 50ch; margin: var(--s-3) 0 var(--s-5); }

  /* ---- Related industries section ---- */
  .related {
    border-top: 1px solid var(--hairline);
  }
  .related-list {
    list-style: none;
    padding: 0;
    margin-top: var(--s-5);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-4);
  }
  .related-list li a {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    border: 1px solid var(--hairline);
    padding: var(--s-5) var(--s-4);
    background: var(--bg);
    transition: border-color var(--t-fast) var(--ease);
    height: 100%;
  }
  .related-list li a:hover {
    border-color: var(--royal);
  }
  .rl-title {
    font-size: var(--text-base);
    font-weight: var(--w-medium);
    margin-bottom: var(--s-2);
    color: var(--fg);
  }
  .rl-dek {
    color: var(--ink-soft);
    font-size: var(--text-sm);
    line-height: 1.5;
  }

  @media (max-width: 880px) {
    .ind-grid { grid-template-columns: 1fr; gap: var(--s-5); }
  }
  @media (max-width: 768px) {
    .related-list {
      grid-template-columns: 1fr;
    }
  }
</style>
