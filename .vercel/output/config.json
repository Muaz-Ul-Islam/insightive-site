{
	"version": 3,
	"routes": [
		{
			"src": "^/(.*)/$",
			"headers": {
				"Location": "/$1"
			},
			"status": 308
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)$",
			"dest": "_render"
		},
		{
			"src": "^/_image$",
			"dest": "_render"
		},
		{
			"src": "^/careers$",
			"dest": "_render"
		},
		{
			"src": "^/contact$",
			"dest": "_render"
		},
		{
			"src": "^/industries/([^/]+?)$",
			"dest": "_render"
		},
		{
			"src": "^/industries$",
			"dest": "_render"
		},
		{
			"src": "^/insights/([^/]+?)$",
			"dest": "_render"
		},
		{
			"src": "^/insights$",
			"dest": "_render"
		},
		{
			"src": "^/partners$",
			"dest": "_render"
		},
		{
			"src": "^/services/advisory$",
			"dest": "_render"
		},
		{
			"src": "^/services/build$",
			"dest": "_render"
		},
		{
			"src": "^/services$",
			"dest": "_render"
		},
		{
			"src": "^/thesis$",
			"dest": "_render"
		},
		{
			"src": "^/work$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "/404.html",
			"status": 404
		}
	]
}