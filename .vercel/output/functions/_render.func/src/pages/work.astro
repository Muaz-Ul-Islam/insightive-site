---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { fetchPage, fetchWork, lexicalNodeToHtml } from '../lib/payload';

let pageData: any = null;
let cmsWork: any[] = [];
try {
  pageData = await fetchPage('work');
  cmsWork = await fetchWork();
} catch (e) {
  console.warn('[Work Page] Failed to fetch data from Payload CMS, using static fallback.', e);
}

const metaTitle = pageData?.meta?.title || pageData?.title || "Work — Outcomes, Not Logos | Insightive";
const metaDescription = pageData?.meta?.description || "Selected fit-built software outcomes across recruitment, commerce and operations, anonymized until clients say otherwise. Industry, misfit, result.";

const layout = pageData?.layout || [];
const hasDynamicLayout = layout.length > 0;

// Normalize CMS work items or fall back to local collection
const localWork = await getCollection('work');
const localWorkSorted = localWork.sort((a, b) => a.data.order - b.data.order);

const workItems = cmsWork.length > 0
  ? cmsWork.map((w: any) => ({
      title: w.title,
      industry: w.customIndustry || (typeof w.industry === 'object' ? w.industry?.name : w.industry),
      scale: w.scale,
      misfit: w.misfit,
      outcome: w.outcome,
    }))
  : localWorkSorted.map((w: any) => ({
      title: w.data.title,
      industry: w.data.industry,
      scale: w.data.scale,
      misfit: w.data.misfit,
      outcome: w.data.outcome,
    }));
---

<Base
  title={metaTitle}
  description={metaDescription}
>
  {hasDynamicLayout ? (
    layout.map((block: any) => {
      const { blockType } = block;

      if (blockType === 'sectionProse') {
        const titleNode = block.title?.root;
        let titleHtml = '';
        if (titleNode) {
          const parsed = lexicalNodeToHtml(titleNode, { italicClass: 'serif-em tick' });
          titleHtml = parsed.replace(/^<[a-zA-Z0-9]+>/, '').replace(/<\/[a-zA-Z0-9]+>$/, '');
        }
        const contentHtml = block.content?.root ? lexicalNodeToHtml(block.content.root) : '';
        const isNoteOnly = !block.eyebrow && !titleHtml;

        if (isNoteOnly) {
          // Content-only prose → render as work-note (e.g. footer note with inline links)
          return (
            <section class="section">
              <div class="container">
                {contentHtml && <div class="work-note" set:html={contentHtml} />}
              </div>
            </section>
          );
        }

        return (
          <section class="section">
            <div class="container">
              {block.eyebrow && <p class="eyebrow">{block.eyebrow}</p>}
              {titleHtml ? (
                <h1 set:html={titleHtml} />
              ) : null}
              {contentHtml && <div class="sub" set:html={contentHtml} />}
            </div>
          </section>
        );
      }

      if (blockType === 'workList') {
        return (
          <>
            <section class="container work-list">
              {workItems.map((w: any) => (
                <article class="work-card">
                  <div class="work-meta">
                    <span class="w-industry">{w.industry}</span>
                    <span class="w-scale">{w.scale}</span>
                  </div>
                  <h2>{w.title}</h2>
                  <div class="work-cols">
                    <div>
                      <p class="col-label">The misfit</p>
                      <p>{w.misfit}</p>
                    </div>
                    <div>
                      <p class="col-label">The outcome</p>
                      <p>{w.outcome}</p>
                    </div>
                  </div>
                </article>
              ))}
            </section>
          </>
        );
      }

      return null;
    })
  ) : (
    <>
      <!-- ============ STATIC FALLBACK ============ -->
      <section class="section">
        <div class="container">
          <p class="eyebrow">Work</p>
          <h1>Outcomes, not <span class="serif-em tick">logos</span>.</h1>
          <p class="sub">
            Selected engagements, anonymized. We publish the misfit and the result, not the
            client's name, until they say otherwise. Named case studies are added as
            permissions land.
          </p>
        </div>
      </section>

      <section class="container work-list">
        {workItems.map((w: any) => (
          <article class="work-card">
            <div class="work-meta">
              <span class="w-industry">{w.industry}</span>
              <span class="w-scale">{w.scale} Build</span>
            </div>
            <h2>{w.title}</h2>
            <div class="work-cols">
              <div>
                <p class="col-label">The misfit</p>
                <p>{w.misfit}</p>
              </div>
              <div>
                <p class="col-label">The outcome</p>
                <p>{w.outcome}</p>
              </div>
            </div>
          </article>
        ))}
      </section>

      <section class="section">
        <div class="container">
          <p class="work-note">
            Want the detail behind any of these: architecture, team shape, delivery timeline?
            <a class="link-quiet" href="/contact">Ask us directly</a>. We walk qualified
            prospects through the full anatomy.
          </p>
        </div>
      </section>
    </>
  )}
</Base>

<style>
  section h1 { font-size: var(--text-2xl); font-weight: var(--w-light); margin: var(--s-4) 0; }
  .sub { max-width: 56ch; font-size: var(--text-md); color: var(--ink-soft); }
  .work-list { display: flex; flex-direction: column; gap: var(--s-4); }
  .work-card { border: 1px solid var(--hairline); padding: var(--s-5); }
  .work-meta {
    display: flex;
    gap: var(--s-3);
    font-family: var(--mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--s-3);
  }
  .w-industry { color: var(--ink-mute); }
  .w-scale { color: var(--royal); }
  .work-card h2 { font-size: var(--text-lg); margin-bottom: var(--s-4); }
  .work-cols { display: grid; grid-template-columns: 1fr 1fr; gap: var(--s-5); }
  .col-label {
    font-family: var(--mono);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--royal);
    margin-bottom: var(--s-2);
  }
  .work-cols p:not(.col-label) { color: var(--ink-soft); font-size: var(--text-sm); }
  .work-note { max-width: 56ch; color: var(--ink-soft); }
  @media (max-width: 880px) {
    .work-cols { grid-template-columns: 1fr; gap: var(--s-3); }
  }
</style>
