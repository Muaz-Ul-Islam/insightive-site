---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { fetchPage, fetchIndustries, lexicalNodeToHtml } from '../../lib/payload';

// ── CMS Data Fetching ────────────────────────────────────────────────────────
let pageData: any = null;
let cmsIndustries: any[] = [];

try {
  pageData = await fetchPage('industries');
} catch (e) {
  console.warn('[Industries] Failed to fetch industries page copy from Payload CMS.', e);
}

try {
  cmsIndustries = await fetchIndustries();
} catch (e) {
  console.warn('[Industries] Failed to fetch industries from Payload CMS.', e);
}

const hasCmsIndustries = cmsIndustries.length > 0;

// ── Fallback Local Markdown ──────────────────────────────────────────────────
const localIndustries = hasCmsIndustries
  ? []
  : (await getCollection('industries')).sort((a, b) => a.data.order - b.data.order);

const industries = hasCmsIndustries
  ? cmsIndustries.filter((ind: any) => ind.isVisible !== false)
  : localIndustries;
  
// ── Hero Block Parsing ───────────────────────────────────────────────────────
const layout = pageData?.layout || [];
const heroBlock = layout.find((b: any) => b.blockType === 'heroBlock' || b.blockType === 'industryHero');

let heroTitleHtml = '';
if (heroBlock?.title?.root) {
  const raw = lexicalNodeToHtml(heroBlock.title.root, { italicClass: 'serif-em tick' });
  // Remove wrapper element if any
  heroTitleHtml = raw.replace(/^<[a-zA-Z0-9]+>/, '').replace(/<\/[a-zA-Z0-9]+>$/, '');
}

const heroEyebrow = heroBlock?.eyebrow ?? 'Industries';
const heroSubtitle = heroBlock?.subtitle ?? "The near-fit tax shows up wherever vendors template a market's average process onto your specific one. These are the industries where we've seen the misfit up close and built what fixed it.";

// ── Meta copy ────────────────────────────────────────────────────────────────
const metaTitle = pageData?.meta?.title || pageData?.title || 'Industries — Where the Misfit Hurts | Insightive';
const metaDescription = pageData?.meta?.description || 'Fit-built software for retail and commerce, real estate, HR and talent, healthcare and education, where rented near-fit systems tax the operation hardest.';

const PAYLOAD_CMS_URL = import.meta.env.PAYLOAD_CMS_URL || import.meta.env.PUBLIC_PAYLOAD_URL || 'http://127.0.0.1:3000';

function getSlug(ind: any): string {
  return ind.slug ?? ind.id?.replace(/\.md$/, '') ?? '';
}

function getIcon(ind: any): string {
  // CMS: icon is now an uploaded media object
  const icon = ind.icon;
  if (icon && typeof icon === 'object' && icon.url) {
    const src = icon.url.startsWith('http') ? icon.url : `${PAYLOAD_CMS_URL}${icon.url}`;
    const alt = icon.alt || '';
    return `<img src="${src}" alt="${alt}" loading="lazy" />`;
  }
  return '';
}

function getName(ind: any): string {
  return ind.name ?? ind.data?.name ?? '';
}

function getDek(ind: any): string {
  return ind.dek ?? ind.data?.dek ?? '';
}
---

<Base title={metaTitle} description={metaDescription}>
  <section class="section">
    <div class="container">
      <p class="eyebrow">{heroEyebrow}</p>
      {heroTitleHtml ? (
        <h1 set:html={heroTitleHtml} />
      ) : (
        <h1>Every industry bends <span class="serif-em tick">differently</span>.</h1>
      )}
      <p class="sub">{heroSubtitle}</p>
    </div>
  </section>

  <section class="container ind-list">
    {industries.map((ind: any) => {
      const slug = getSlug(ind);
      return (
        <a class="ind-card" href={`/industries/${slug}`}>
          <span class="ind-ico" aria-hidden="true" set:html={getIcon(ind)} />
          <h2>{getName(ind)}</h2>
          <p>{getDek(ind)}</p>
          <span class="ind-cta">The misfit pattern →</span>
        </a>
      );
    })}
  </section>

  <section class="section">
    <div class="container">
      <p class="ind-note">
        Operating somewhere else? The thesis doesn't care about verticals: if your process
        is bending to software, <a class="link-quiet" href="/contact">start a conversation</a>.
      </p>
    </div>
  </section>
</Base>

<style>
  section h1 { font-size: var(--text-2xl); font-weight: var(--w-light); margin: var(--s-4) 0; }
  .sub { max-width: 56ch; font-size: var(--text-md); color: var(--ink-soft); }
  .ind-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-4);
  }
  .ind-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    border: 1px solid var(--hairline);
    padding: var(--s-6) var(--s-5);
    min-height: 240px;
    transition: border-color var(--t-fast) var(--ease);
  }
  .ind-card:hover { border-color: var(--royal); }
  .ind-ico {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: var(--royal);
    border: 1px solid var(--hairline);
    margin-bottom: var(--s-4);
    transition: border-color var(--t-fast) var(--ease);
  }
  .ind-ico :global(svg) { width: 22px; height: 22px; }
  .ind-ico :global(img) { width: 22px; height: 22px; object-fit: contain; display: block; }
  .ind-card:hover .ind-ico { border-color: var(--royal); }
  .ind-card h2 { font-size: var(--text-lg); margin-bottom: var(--s-2); }
  .ind-card p { color: var(--ink-soft); font-size: var(--text-base); }
  .ind-cta {
    display: inline-block;
    margin-top: auto;
    padding-top: var(--s-4);
    font-weight: var(--w-medium);
    font-size: var(--text-sm);
    color: var(--royal);
  }
  .ind-note { max-width: 56ch; color: var(--ink-soft); }
  @media (max-width: 880px) {
    .ind-list { grid-template-columns: 1fr; }
  }
</style>
